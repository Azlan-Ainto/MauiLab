<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MyProfilis.SearchPage"
    Title="Personensuche"
    BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20">

        <!-- Header -->
        <VerticalStackLayout Spacing="4">
            <Label Text="Personensuche"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#111827" />

            <Label Text="Suchen, auswählen und Details anzeigen"
                   FontSize="14"
                   TextColor="#6B7280" />
        </VerticalStackLayout>

        <!-- Hauptbereich -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="20"
                             Margin="0,20,0,0">

            <!-- Suchbereich -->
            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="10"
                    StrokeShape="RoundRectangle 18">

                <Border.Shadow>
                    <Shadow Brush="#20000000"
                            Offset="0,4"
                            Radius="14"
                            Opacity="0.8" />
                </Border.Shadow>

                <SearchBar
                    Placeholder="Nach Name suchen..."
                    FontSize="16"
                    BackgroundColor="Transparent"
                    Text="{Binding SearchText}"
                    SearchCommand="{Binding SearchCommand}" />
            </Border>

            <!-- Ergebnisliste -->
            <CollectionView ItemsSource="{Binding Personen}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                           ItemSpacing="8" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="0"
                                BackgroundColor="White"
                                Padding="15"
                                Margin="0,6"
                                StrokeShape="RoundRectangle 18">

                            <Border.Shadow>
                                <Shadow Brush="#20000000"
                                        Offset="0,3"
                                        Radius="10"
                                        Opacity="0.6" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto,*"
                                  VerticalOptions="Center"
                                  >

                                <!-- Avatar -->
                                <Border WidthRequest="44"
                                        HeightRequest="44"
                                        BackgroundColor="#2563EB"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 22"
                                        VerticalOptions="Center">

                                    <Label Text="{Binding Vorname}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="14" />
                                </Border>

                                <!-- Personendaten -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Margin="14,0,0,0"
                                                     Spacing="2">

                                    <Label Text="{Binding Vorname}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#111827"/>

                                    <Label Text="{Binding Nachname}"
                                           FontSize="14"
                                           TextColor="#374151"/>

                                    <Label Text="{Binding Stadt}"
                                           FontSize="13"
                                           TextColor="#9CA3AF"/>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

        <!-- Detailbereich -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="20"
                Margin="0,20,0,0"
                StrokeShape="RoundRectangle 22"
                IsVisible="{Binding IsPersonSelected}">

            <Border.Shadow>
                <Shadow Brush="#30000000"
                        Offset="0,6"
                        Radius="18"
                        Opacity="0.8" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="10">

                <Label Text="Detailansicht"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#111827" />

                <BoxView HeightRequest="1"
                         Color="#E5E7EB" />

                <Label Text="{Binding SelectedPerson.Vorname}"
                       FontSize="16"
                       FontAttributes="Bold"/>

                <Label Text="{Binding SelectedPerson.Nachname}" />
                <Label Text="{Binding SelectedPerson.EMail}" />
                <Label Text="{Binding SelectedPerson.Telefon}" />
                <Label Text="{Binding SelectedPerson.Stadt}" />

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>
    
    
    
